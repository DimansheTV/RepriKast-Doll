server {
    listen 80;
    server_name _;

    root /var/www/reprikast-doll/dist;
    index index.html;

    location = / {
        try_files /index.html =404;
    }

    location = /compare.html {
        try_files /compare.html =404;
    }

    location / {
        try_files $uri $uri/ =404;
    }

    types {
        application/javascript js mjs;
        application/json json;
        text/css css;
        image/webp webp;
        image/png png;
        image/jpeg jpg jpeg;
        image/gif gif;
        image/svg+xml svg;
    }
}
